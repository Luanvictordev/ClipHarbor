# Opcional: nome exibido na UI
# APP_NAME=ClipHarbor

# Produção na Vercel: criado automaticamente ao ligar Vercel Blob ao projeto
# BLOB_READ_WRITE_TOKEN=

# Opcional: caminho do ffmpeg se não usar imageio-ffmpeg
# FFMPEG_PATH=

# YouTube (e alguns sites): exporte cookies no formato Netscape e use UM dos dois:
# - Caminho local do arquivo cookies.txt:
# YT_DLP_COOKIES_FILE=C:\caminho\cookies-youtube.txt
# - Ou conteúdo do arquivo em Base64 (útil na Vercel: variável de ambiente):
# YT_DLP_COOKIES_B64=
# Como exportar: https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies
# Cookies expiram; atualize quando o yt-dlp voltar a falhar.
